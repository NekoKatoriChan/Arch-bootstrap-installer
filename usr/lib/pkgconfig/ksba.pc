prefix=/data/data/com.termux/files/usr
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=/data/data/com.termux/files/usr/lib
host=aarch64-unknown-linux-android
api_version=1

Name: ksba
Description: X.509 and CMS support library
Requires: gpg-error
Version: 1.6.7
Cflags: -I${includedir} 
Libs: -L${libdir} -lksba
URL: https://www.gnupg.org/related_software/libksba/
